{
  "name": "live-tv",
  "version": "1.0.0",
  "description": "Live TV Controller",
  "type": "module",
  "main": "smk-launcher.cjs",
  "bin": "smk-launcher.cjs",
  "scripts": {
    "smk": "node smk.cjs",
    "dev": "node smk.cjs dev",
    "build": "node smk.cjs build",
    "exe": "node smk.cjs exe",
    "start": "node smk.cjs start",
    "stop": "node smk.cjs stop",
    "install:all": "node smk.cjs install",
    "build:exe": "node build.cjs"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.11.5",
    "esbuild": "^0.24.0"
  },
  "pkg": {
    "scripts": [
      "smk-launcher.cjs",
      "live-tv-api/.bundle.cjs",
      "live-tv-controller-react/server.cjs",
      "live-tv-controller-react/scheduler-service.cjs",
      "live-tv-controller-react/state-service.cjs"
    ],
    "assets": [
      "live-tv-controller-react/dist/**/*"
    ],
    "targets": [
      "node20-win-x64"
    ],
    "outputPath": "."
  }
}
